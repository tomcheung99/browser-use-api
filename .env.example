# LLM providers — set at least one
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
KIMI_API_KEY=sk-kimi-...

# Default LLM settings
# Supported providers: openai | anthropic | kimi
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
# For Kimi, use: DEFAULT_LLM_PROVIDER=kimi, DEFAULT_MODEL=kimi-for-coding

# Set to false only for local debugging (Railway must use true)
HEADLESS=true

# Optional: protect your API with a bearer token
API_SECRET_KEY=

# Browser timeout in ms
BROWSER_TIMEOUT=30000
